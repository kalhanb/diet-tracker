generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String      @id @default(cuid())
  email                String      @unique
  name                 String
  age                  Int
  gender               String
  weight               Float
  height               Float
  activityLevel        String
  goalType             String
  dailyCalories        Int
  dailyWaterGoal       Int         @default(2000)
  targetWeight         Float
  streak               Int         @default(0)
  lastLogDate          DateTime?
  
  // Subscription Fields
  subscriptionStatus   String      @default("free") // "free", "active", "canceled"
  subscriptionPlan     String?     // "basic", "premium", "elite"
  stripeCustomerId     String?     @unique
  stripeSubscriptionId String?     @unique

  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  logs                 DietLog[]
  weightLogs           WeightLog[]
  waterLogs            WaterLog[]
  dietPlanHistory      DietPlanArchive[]
  pantry               PantryItem[]
  
  // Clinical markers
  ldlLevel             String?
  glucoseLevel         String?
  bloodPressure        String?
  medications          String?
  healthConditions     String?
}

model WaterLog {
  id        String   @id @default(cuid())
  amount    Int      // in ml
  date      DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model DietPlanArchive {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  planText  String   @db.Text
  isFavorite Boolean  @default(false)
  date      DateTime @default(now())
}

model DietLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime @default(now())
  foodName  String
  calories  Int
  protein   Float
  carbs     Float
  fat       Float
  mealType  String   
  mood      String?  // Energetic, Bloated, Tired, Neutral
}

model WeightLog {
  id      String   @id @default(uuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id])
  date    DateTime @default(now())
  weight  Float
}

model PantryItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String   // User only needs to provide the name
}

model GlobalConfig {
  id             String   @id @default("active_config")
  activeProvider String   @default("gemini") // gemini, openai, anthropic
  activeModel    String   @default("gemini-3.0-flash")
  updatedAt      DateTime @updatedAt
}
